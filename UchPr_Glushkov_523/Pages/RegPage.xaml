<Page x:Class="UchPr_Glushkov_523.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2.7*"/>
            <ColumnDefinition Width="2.7*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Регистрация" FontSize="35" Grid.ColumnSpan="2" Margin="15"/>
        <Button x:Name="BackBtn" Grid.Column="0" Width="100" Height="50" HorizontalAlignment="Left" 
                VerticalAlignment="Bottom" Margin="10" Content="Назад" FontSize="20" Click="BackBtn_Click"/>
        <StackPanel Grid.Column="1">
            <Label Content="Логин:" Margin="15,100,0,0" FontSize="25"/>
            <TextBox x:Name="LoginTB" Height="40" Width="300" TextChanged="NameTB_TextChanged"/>
            <Label Content="Пароль:" Margin="15,40,0,0" FontSize="25"/>
            <TextBox x:Name="PassTB" Height="40" Width="300" TextChanged="NameTB_TextChanged"/>
        </StackPanel>
        <StackPanel Grid.Column="2">
            <Label Content="Почта:" Margin="15,100,0,0" FontSize="25"/>
            <TextBox x:Name="EmailTB" Height="40" Width="300" TextChanged="NameTB_TextChanged"/>
            <Label Content="Имя:" Margin="15,40,0,0" FontSize="25"/>
            <TextBox x:Name="NameTB" Height="40" Width="300" TextChanged="NameTB_TextChanged"/>
        </StackPanel>
        <Button x:Name="RegBtn" Grid.Column="2" Width="100" Height="50" HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" Margin="10" Content="Регистрация" FontSize="15" IsEnabled="False" Click="RegBtn_Click"/>
    </Grid>
</Page>
