<Page x:Class="UchPr_Glushkov_523.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="1">
            <Grid>
                <StackPanel>
                    <Button x:Name="ButtCatalog" Height="100" Margin="10" Click="ButtCatalog_Click" Background="Transparent">
                        <Image Source="/Images/catalog.png"/>
                    </Button>
                    <Button x:Name="ButtBookList" Height="100" Margin="10" Click="ButtBookList_Click" Background="Transparent">
                        <Image Source="/Images/list.png"/>
                    </Button>
                    <Button x:Name="ButtAdmin" Height="100" Margin="10" Click="ButtAdmin_Click"  Background="Transparent">
                        <Image Source="/Images/hat.png"/>
                    </Button>
                    <Button x:Name="ButtAuthor" Height="100" Margin="10" Click="ButtAuthor_Click"  Background="Transparent">
                        <Image Source="/Images/pen.png"/>
                    </Button>
                    <Button x:Name="ButtUser" Height="100" Margin="10" Click="ButtUser_Click"  Background="Transparent">
                        <Image Source="/Images/user.png"/>
                    </Button>
                    <Button x:Name="ButtWarn" Height="100" Margin="10" Click="ButtWarn_Click"  Background="Transparent">
                        <Image Source="/Images/warning.png"/>
                    </Button>
                </StackPanel>
            </Grid> 
        </ScrollViewer>
        <Frame Grid.Column="0" x:Name="MainePage" NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
