<Page x:Class="UchPr_Glushkov_523.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage"
      Background="Salmon">

    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <Label Content="Шут и Кроль" Margin="0,30,0,0" FontSize="35"/>
            <Label Content="Логин:" Margin="0,25,0,5" FontSize="20"/>
            <TextBox x:Name="LoginTB" Height="35" TextChanged="PassTB_TextChanged"/>
            <Label Content="Пароль:" Margin="0,10,0,5" FontSize="20"/>
            <TextBox x:Name="PassTB" Height="35" TextChanged="PassTB_TextChanged"/>
            <Button x:Name="AuthBtn" Height="40" Width="150" Margin="0, 20" Content="Войти" FontSize="25" IsEnabled="False" Click="AuthBtn_Click"/>
            <Label Content="Нет аккаунта?" x:Name="RegLabel" HorizontalAlignment="Center" MouseDoubleClick="RegLabel_MouseDoubleClick">
                <Label.Style>
                    <Style TargetType="Label">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="LightBlue"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>
        </StackPanel>
    </Grid>
</Page>
