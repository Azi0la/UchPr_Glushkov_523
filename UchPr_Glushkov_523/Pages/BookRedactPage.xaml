<Page x:Class="UchPr_Glushkov_523.Pages.BookRedactPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookRedactPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label x:Name="BookRedLB" Content="" FontSize="20" Margin="10" Grid.ColumnSpan="2" />

        <StackPanel HorizontalAlignment="Center" Margin="0,80,0,0" Grid.Column="0">
            <TextBlock x:Name="TitleTBl" Text="Название книги" FontSize="20" TextWrapping="Wrap" />
            <TextBox x:Name="TitleTB" Width="200" Height="50"/>

            <TextBlock x:Name="DescriptionTBl" Text="Описание книги" FontSize="20" Margin="0,40,0,0"/>
            <TextBox x:Name="DescriptionTB" Width="200" Height="150" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0" Grid.Column="1">
            <TextBlock x:Name="PathTBl" Text="Путь до обложки" FontSize="20" />
            <TextBox x:Name="PathTB" Width="200"/>

            <TextBlock x:Name="FillingTBl" Text="Наполнение книги" FontSize="20" Margin="0,40,0,0"/>
            <TextBox x:Name="FillingTB" Width="200" Height="200" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Жанры" VerticalAlignment="Bottom" FontSize="20"/>
            <ListBox Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
         x:Name="GenreList" Height="375" 
         VerticalAlignment="Top" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}"  
                      Tag="{Binding ID}" 
                      Click="GenreBox_Click" x:Name="GenreBox" 
                      Checked="GenreBox_Checked" Unchecked="GenreBox_Unchecked" Loaded="GenreBox_Loaded"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button x:Name="SaveBTN" Grid.Row="2" Height="50" Width="150" HorizontalAlignment="Right" 
                    Margin="0,0,10,0" Content="Сохранить" FontSize="25" Click="SaveBTN_Click"/>
        </Grid>

    </Grid>
</Page>
