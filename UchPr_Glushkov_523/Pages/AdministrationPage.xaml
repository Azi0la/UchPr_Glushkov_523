<Page x:Class="UchPr_Glushkov_523.Pages.AdministrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdministrationPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="7.5*"/>
         </Grid.RowDefinitions>
            <Label Content="Пользователи" HorizontalAlignment="Center" FontSize="15" Grid.Row="0"></Label>
            <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="AdmUserList"
MouseDoubleClick="AdmUserList_MouseDoubleClick" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="1" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"/>
                            <TextBlock Text="{Binding Login}"/>
                            <TextBlock Text="{Binding Role.RoleName}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Stretch">
                        </WrapPanel>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>

        <Label Content="Замороженные" HorizontalAlignment="Center" FontSize="15" Grid.Row="0" Grid.Column="1"></Label>
        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="FrozenList"
                 Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding type, StringFormat=Тип: {0}}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding name}" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding motive}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Stretch">
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <Label Content="Заявки на &#10;авторство" HorizontalAlignment="Center" FontSize="15" Grid.Row="0" Grid.Column="2"></Label>
        <ListBox ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="ApplicList" MouseDoubleClick="ApplicList_MouseDoubleClick"
         Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="1" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding User.Name}"/>
                        <TextBlock Text="{Binding Reason}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Stretch">
                    </WrapPanel>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <Label Content="Заявки на &#10;разморозку" HorizontalAlignment="Center" FontSize="15" Grid.Row="0" Grid.Column="3"></Label>

        <Label Content="Жалобы" HorizontalAlignment="Center" FontSize="15" Grid.Row="0" Grid.Column="4"></Label>

    </Grid>
</Page>
