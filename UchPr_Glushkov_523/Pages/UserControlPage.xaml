<Page x:Class="UchPr_Glushkov_523.Pages.UserControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserControlPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label x:Name="userLB" Content="Данные пользователя: " FontSize="35" Margin="10,10,0,0" Grid.ColumnSpan="2"/>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,0,0,0">
            <Label Content="Роль пользователя:" FontSize="20" Margin="0,0,0,10"/>
            <ComboBox x:Name="RoleCB" Height="25"/>
        </StackPanel>

        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Пароль аккаунта:" FontSize="20" Margin="0,0,0,0"/>
            <TextBox x:Name="UserPassTB" Height="40" Width="200"/>
        </StackPanel>

        <Button x:Name="SaveBTN" Grid.Column="1" Height="50" 
                Width="150" Margin="15" VerticalAlignment="Bottom" 
                HorizontalAlignment="Right" Content="Сохранить" FontSize="25" Click="SaveBTN_Click"/>
    </Grid>
</Page>
