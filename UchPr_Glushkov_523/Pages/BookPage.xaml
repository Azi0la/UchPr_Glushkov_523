<Page x:Class="UchPr_Glushkov_523.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Image Source="{Binding ImagePath}" Width="150" Height="200" Margin="0,10,0,0"/>
            <Button x:Name="ReadBTN" Width="150" Height="50" Content="Читать" FontSize="25" Margin="0,15,0,0"/>
            <Button x:Name="ReviewBTN" Width="150" Height="50" Content="Написать отзыв" FontSize="16" Margin="0,15,0,0"/>
            <Button x:Name="BackBTN" Width="150" Height="50" Content="Назад" FontSize="25" Margin="0,15,0,0" Click="BackBTN_Click" VerticalAlignment="Bottom"/>
        </StackPanel>

    </Grid>
</Page>
