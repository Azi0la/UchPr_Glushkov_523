<Page x:Class="UchPr_Glushkov_523.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserPage"
      Background="Salmon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Top">
            <TextBlock Text="{Binding Name, StringFormat=Имя: {0}}" Margin="20,20,0,0" FontSize="20"/>
            <TextBlock Text="{Binding Login, StringFormat=Логин: {0}}" Margin="20,5,0,0" FontSize="20"/>
            <TextBlock Text="{Binding Email, StringFormat=Почта: {0}}" Margin="20,5,0,0" FontSize="20"/>
            <TextBlock Text="{Binding Role.RoleName, StringFormat=Роль: {0}}" Margin="20,5,0,0" FontSize="20"/>
        </StackPanel>
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20">
            <TextBlock x:Name="WarnTB" FontSize="25"/>
            <Button x:Name="WarnBTN" Width="150" Height="50" Content="Оспорить &#x0a;заморозку" FontSize="15" Visibility="Hidden"/>
        </StackPanel>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>

            <Label Content="Отзывы" HorizontalAlignment="Center" FontSize="20" Grid.Row="0"></Label>
            <ListBox x:Name="RevUsList" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Book.Title}"/>
                            <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}}"/>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Stretch" Orientation="Vertical">
                        </WrapPanel>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
        <Button x:Name="ApplicBTN" Height="50" Width="150" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20" Visibility="Visible" Content="Податься &#x0a;в авторы" FontSize="15" Click="ApplicBTN_Click"/>
    </Grid>
</Page>
