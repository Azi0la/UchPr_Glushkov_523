<Page x:Class="UchPr_Glushkov_523.AdminBlockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UchPr_Glushkov_523"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminBlockPage"
      Background="Salmon">

    <Grid>
        <StackPanel Orientation="Horizontal">
            <Label x:Name="CompLB" FontSize="35" Margin="10,10,0,0"/>
            <Label x:Name="AuthLB" FontSize="20" Margin="-10,25,0,0"/>
            <Label x:Name="ReviewLB" FontSize="20" Margin="-10,25,0,0"/>
        </StackPanel>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Тип нарушения: " FontSize="25" />
            <ComboBox x:Name="MotiveCB" Height="30" SelectionChanged="MotiveCB_SelectionChanged"/>
        </StackPanel>

        <Button x:Name="SendBTN" Height="50" Width="100" 
        VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="15" 
        Content="Заморозить" Click="SendBTN_Click" FontSize="15" IsEnabled="False"/>
    </Grid>
</Page>
